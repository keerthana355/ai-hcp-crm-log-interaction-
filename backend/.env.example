# Copy this file to .env and fill in real values. Never commit the real .env.

DATABASE_URL=mysql+pymysql://hcp_app:YourStrongPassword123@localhost:3306/hcp_crm

# Groq API — create a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_PRIMARY=openai/gpt-oss-20b
GROQ_MODEL_FALLBACK=openai/gpt-oss-120b

# Auth
JWT_SECRET_KEY=change_this_to_a_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
